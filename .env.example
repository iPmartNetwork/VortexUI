# --- Panel (control plane) ---
VORTEX_HTTP_ADDR=:8080
VORTEX_GRPC_ADDR=:50051
VORTEX_DATABASE_URL=postgres://vortex:vortex@localhost:5432/vortex?sslmode=disable
VORTEX_REDIS_URL=redis://localhost:6379/0
# Must be >= 32 bytes. Generate: openssl rand -hex 32
VORTEX_JWT_SECRET=
VORTEX_JWT_TTL=1h

# mTLS material for the node hub (panel side)
VORTEX_TLS_CERT=./deploy/certs/panel.crt
VORTEX_TLS_KEY=./deploy/certs/panel.key
VORTEX_TLS_CA=./deploy/certs/ca.crt

# --- Notifications (optional; empty = disabled) ---
# Webhook: every domain event (user.limited, user.expired, node.down, ...) is
# POSTed as JSON. If a secret is set, the body is signed with HMAC-SHA256 in the
# X-Vortex-Signature header (sha256=<hex>).
VORTEX_WEBHOOK_URL=
VORTEX_WEBHOOK_SECRET=

# Telegram notifier: events are sent as messages to the chat. Needs both values.
VORTEX_TELEGRAM_TOKEN=
VORTEX_TELEGRAM_CHAT_ID=

# --- Local node (optional) ---
# Run a proxy core on the panel host itself, managed in-process (no separate
# node agent / mTLS). Inbounds/users attach to it like any other node.
VORTEX_LOCAL_NODE=false
VORTEX_LOCAL_NODE_NAME=local
# Public host advertised to clients in subscriptions for this node.
VORTEX_LOCAL_NODE_HOST=127.0.0.1
VORTEX_CORE=xray                       # or: singbox
VORTEX_CORE_BIN=/usr/local/bin/xray    # singbox: /usr/local/bin/sing-box
VORTEX_CORE_CONFIG=/etc/vortex/local-core.json
VORTEX_CORE_API_PORT=10085
# Per-user traffic stats on sing-box need a binary built with -tags with_v2ray_api.
# Omit to auto-default (false for singbox, true for xray). Stock sing-box needs false.
# VORTEX_SINGBOX_V2RAY_API=false
